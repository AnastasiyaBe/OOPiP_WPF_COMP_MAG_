<Window x:Class="ComputerStoreWPF.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог товаров" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Товары" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="ProductsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8"
                                Width="220" Margin="12" Padding="8" Background="White">
                            <StackPanel>
                                <Border Background="LightGray" Height="150" CornerRadius="5"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="[Изображение]" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" FontSize="14"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                           FontSize="16" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Price, StringFormat={}{0:C2} BYN}"
                                           Foreground="Green" FontSize="14" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding StockQuantity,
                                    StringFormat=Остаток: {0} шт.}" FontSize="12"
                                           Foreground="Gray"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>