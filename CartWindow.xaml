<Window x:Class="ComputerStoreWPF.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Корзина" Height="450" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView Name="CartListView">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Выбрать" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                          Click="SelectionChanged"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Товар" Width="200" DisplayMemberBinding="{Binding Product.Name}"/>
                    <GridViewColumn Header="Цена (BYN)" Width="100" DisplayMemberBinding="{Binding Product.Price, StringFormat={}{0:F2}}"/>
                    <GridViewColumn Header="Количество" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Name="DecreaseBtn" Content="-" Width="30" Click="Decrease_Click" Tag="{Binding}"/>
                                    <TextBlock Text="{Binding Quantity}" Width="40" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                    <Button Name="IncreaseBtn" Content="+" Width="30" Click="Increase_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Сумма (BYN)" Width="100" DisplayMemberBinding="{Binding Total, StringFormat={}{0:F2}}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <TextBlock Text="Итого к оплате: " FontSize="16" FontWeight="Bold"/>
            <TextBlock Name="TotalTextBlock" FontSize="16" FontWeight="Bold" Foreground="Green"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Оформить выбранные товары" Width="180" Height="35" Margin="5" Click="Checkout_Click"/>
            <Button Content="Продолжить покупки" Width="140" Height="35" Margin="5" Click="Continue_Click"/>
        </StackPanel>
    </Grid>
</Window>