<Window x:Class="ComputerStoreWPF.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление/редактирование товара" Height="500" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="0" Grid.Column="1" Name="NameTextBox" Margin="5" Height="25"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Характеристики:" VerticalAlignment="Top" Margin="5"/>
        <TextBox Grid.Row="1" Grid.Column="1" Name="CharacteristicsTextBox" Margin="5" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Цена (BYN):" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="2" Grid.Column="1" Name="PriceTextBox" Margin="5" Height="25"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Количество:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="StockTextBox" Margin="5" Height="25"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Путь к картинке:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="4" Grid.Column="1" Name="ImagePathTextBox" Margin="5" Height="25"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Категория:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="5" Grid.Column="1" Name="CategoryCombo" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="5" Height="25"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Производитель:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="6" Grid.Column="1" Name="ManufacturerCombo" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="5" Height="25"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="Сохранить" Width="100" Margin="5" Click="SaveButton_Click" IsDefault="True"/>
            <Button Content="Отмена" Width="100" Margin="5" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>