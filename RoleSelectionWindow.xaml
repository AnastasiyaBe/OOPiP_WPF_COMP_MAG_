<Window x:Class="ComputerStoreWPF.RoleSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин компьютерной техники" Height="250" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="Выберите роль входа" FontSize="20" Margin="0 0 0 25" HorizontalAlignment="Center"/>
            <Button Name="UserButton" Content="Войти как покупатель" Width="220" Height="45" Margin="0 8" Click="UserButton_Click"/>
            <Button Name="AdminButton" Content="Войти как администратор" Width="220" Height="45" Margin="0 8" Click="AdminButton_Click"/>
        </StackPanel>
    </Grid>
</Window>