<Window x:Class="ComputerStoreWPF.PasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход администратора" Height="150" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Введите пароль администратора:" Margin="0 0 0 10"/>
            <PasswordBox Name="PasswordBox" Margin="0 0 0 10"/>
            <Button Name="OkButton" Content="OK" Width="80" Click="OkButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>